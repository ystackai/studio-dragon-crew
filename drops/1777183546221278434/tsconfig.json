{
    "compilerOptions": {
      "target": "ES2020",
      "module": "ES2020",
      "moduleResolution": "bundler",
      "strict": true,
      "esModuleInterop": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "sourceMap": true,
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "noEmitOnError": false
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
